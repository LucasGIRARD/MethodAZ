# Configuration publique de l'installation. Copier vers vps.env.

ADMIN_USER=lucas
ADMIN_SSH_KEY_FILE=install/keys/admin.pub

# Remplacer par le port privé réel. La documentation publique conserve **000.
SSH_PORT=CHANGE_ME
KEEP_SSH_PORT_22=true

ENABLE_SFTP=true
SFTP_USER=depot
SFTP_SSH_KEY_FILE=install/keys/sftp.pub
SFTP_ROOT=/srv/sftp

ENABLE_SWAP=true
SWAP_SIZE=2G
ENABLE_IPV6=true
BACKUP_RETENTION_DAYS=7
BACKUP_MIN_FREE_MB=1024

INSTALL_DOCKER=true
INSTALL_DATABASES=true
INSTALL_GATEWAY=true
INSTALL_MONITORING=true
ENABLE_LOGS=false
ENABLE_CONTAINER_METRICS=false

# Valeurs possibles : linkwarden,davis,freshrss,ttrss,kill-newsletter,web
SERVICES=linkwarden,davis,freshrss,ttrss,web
AUTO_START_SERVICES=false

BASE_DOMAIN=example.fr
ADMIN_EMAIL=contact@example.fr
TIMEZONE=Europe/Paris
DATABASE_NETWORK_PREFIX=vps-db
MONITORING_DOMAIN=monitoring.example.fr

LINKWARDEN_DOMAIN=links.example.fr
LINKWARDEN_URL=https://links.example.fr
DAVIS_DOMAIN=dav.example.fr
FRESHRSS_DOMAIN=freshrss.example.fr
TTRSS_DOMAIN=ttrss.example.fr
TTRSS_URL=https://ttrss.example.fr/
NEWSLETTER_DOMAIN=newsletter.example.fr
WEB_DOMAIN=web.example.fr

LINKWARDEN_VERSION=v2.14.1
LINKWARDEN_DISABLE_REGISTRATION=false
DAVIS_VERSION=4.4.0
FRESHRSS_VERSION=1.29.1
TTRSS_IMAGE=ghcr.io/tt-rss/tt-rss:latest
# Tiny Tiny RSS ne publie qu'un canal roulant. Le digest est verrouillé
# sur le serveur avec vps-image-lock avant le premier démarrage.
POSTGRES_VERSION=16.14-alpine3.23
MARIADB_VERSION=11.8.8-noble
MARIADB_SERVER_VERSION=11.8.8-MariaDB
PHP_BASE_IMAGE=php:8.4.21-apache-trixie
WEB_IMAGE_TAG=8.4.21-1
NGINX_ALPINE_VERSION=1.30.2-alpine-slim

GRAFANA_VERSION=13.0.1-security-01
PROMETHEUS_VERSION=v3.12.0-distroless
PROMETHEUS_RETENTION_TIME=7d
PROMETHEUS_RETENTION_SIZE=512MB
NODE_EXPORTER_VERSION=v1.11.1-distroless
CADVISOR_VERSION=v0.55.1
LOKI_VERSION=3.7.2
ALLOY_VERSION=v1.16.1
ALPINE_VERSION=3.22.4
NGINX_VERSION=1.30.2-alpine-slim
CERTBOT_VERSION=v5.6.0
