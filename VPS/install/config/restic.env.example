# Configuration recommandée pour Koofr via rclone. Le fichier rclone.conf
# contient le mot de passe d'application Koofr sous une forme obscurcie.
RCLONE_CONFIG=/etc/vps-backup/rclone.conf

# Pour conserver un backend S3, commenter RCLONE_CONFIG puis décommenter et
# renseigner les variables suivantes.
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_DEFAULT_REGION=eu-central-1
