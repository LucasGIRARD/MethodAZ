# Générer ce fichier avec scripts/generate-secrets.sh.
# Il doit appartenir à root et conserver le mode 0600.

ADMIN_INITIAL_PASSWORD=CHANGE_ME
# Si cette valeur est remplacée par un hash openssl commençant par $6$,
# conserver les quotes simples pour empêcher l'expansion shell.
ADMIN_PASSWORD_HASH=CHANGE_ME

LINKWARDEN_DB_PASSWORD=CHANGE_ME
LINKWARDEN_NEXTAUTH_SECRET=CHANGE_ME
LINKWARDEN_BOOTSTRAP_PASSWORD=CHANGE_ME

POSTGRES_ADMIN_PASSWORD=CHANGE_ME

DAVIS_DB_PASSWORD=CHANGE_ME
DAVIS_APP_SECRET=CHANGE_ME
DAVIS_ADMIN_PASSWORD=CHANGE_ME

FRESHRSS_DB_PASSWORD=CHANGE_ME

TTRSS_DB_PASSWORD=CHANGE_ME
TTRSS_ADMIN_PASSWORD=CHANGE_ME

WEB_DB_PASSWORD=CHANGE_ME

GRAFANA_HTTP_PASSWORD=CHANGE_ME
