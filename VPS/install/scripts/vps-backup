#!/bin/sh
set -eu
umask 077

FLAG_FILE=${FLAG_FILE:-/etc/default/vps-maintenance}
if [ -r "$FLAG_FILE" ]; then
  # shellcheck disable=SC1090
  . "$FLAG_FILE"
fi

STACK_ROOT=${STACK_ROOT:-/opt/selfhosted}
BACKUP_ROOT=${BACKUP_ROOT:-$STACK_ROOT/backups/files}
BACKUP_RETENTION_DAYS=${BACKUP_RETENTION_DAYS:-7}
BACKUP_MIN_FREE_MB=${BACKUP_MIN_FREE_MB:-1024}
DATE=$(date +%F_%H-%M-%S)
FINAL_DIR="$BACKUP_ROOT/$DATE"

[ "$(id -u)" -eq 0 ] || {
  echo "Exécuter cette commande avec sudo ou comme root." >&2
  exit 1
}

mkdir -p "$BACKUP_ROOT" /run/lock
exec 9>/run/lock/vps-backup.lock
flock -n 9 || {
  echo "Une sauvegarde est déjà en cours." >&2
  exit 1
}

free_mb=$(df -Pm "$BACKUP_ROOT" | awk 'NR == 2 {print $4}')
[ "$free_mb" -ge "$BACKUP_MIN_FREE_MB" ] || {
  echo "Espace libre insuffisant : ${free_mb} Mio disponibles." >&2
  exit 1
}

staging=$(mktemp -d "$BACKUP_ROOT/.backup.XXXXXX")
grafana_stopped=false

cleanup() {
  if [ "$grafana_stopped" = true ]; then
    vps-compose monitoring start grafana >/dev/null 2>&1 || true
  fi
  [ -n "${staging:-}" ] && rm -rf -- "$staging"
}
trap cleanup EXIT HUP INT TERM

mkdir -p "$staging/databases"

if [ -f "$STACK_ROOT/databases/docker-compose.yml" ]; then
  for engine in mariadb postgres; do
    if ! vps-compose databases ps --status running --services 2>/dev/null \
      | grep -qx "$engine"; then
      if find "$STACK_ROOT/databases/$engine" -mindepth 1 -print -quit \
        2>/dev/null | grep -q .; then
        echo "Le moteur $engine est arrêté alors que des données existent." >&2
        exit 1
      fi
    fi
  done

  if vps-compose databases ps --status running --services 2>/dev/null \
    | grep -qx postgres; then
    echo "Dump de l'instance PostgreSQL partagée"
    vps-compose databases exec -T postgres \
      pg_dumpall --clean --if-exists --username postgres \
      > "$staging/databases/postgres.sql"
    gzip -1 "$staging/databases/postgres.sql"
  fi

  if vps-compose databases ps --status running --services 2>/dev/null \
    | grep -qx mariadb; then
    echo "Dump de l'instance MariaDB partagée"
    vps-compose databases exec -T mariadb sh -c \
      'exec mariadb-dump --all-databases --single-transaction --quick --routines --events --user=root --password="$MARIADB_ROOT_PASSWORD"' \
      > "$staging/databases/mariadb.sql"
    gzip -1 "$staging/databases/mariadb.sql"
  fi
fi

set --
for name in databases linkwarden davis kill-newsletter freshrss ttrss web monitoring gateway; do
  [ -d "$STACK_ROOT/$name" ] && set -- "$@" "$name"
done

if [ "$#" -gt 0 ]; then
  echo "Archive des configurations et données applicatives"
  tar -C "$STACK_ROOT" \
    --exclude='databases/mariadb' \
    --exclude='databases/postgres' \
    --exclude='gateway/logs' \
    --exclude='gateway/certbot/logs' \
    -czf "$staging/configurations-et-donnees.tar.gz" "$@"
fi

if [ -f "$STACK_ROOT/monitoring/docker-compose.yml" ] \
  && docker volume inspect monitoring_grafana_data >/dev/null 2>&1; then
  echo "Archive cohérente du volume Grafana"
  if vps-compose monitoring ps --status running --services 2>/dev/null \
    | grep -qx grafana; then
    vps-compose monitoring stop grafana >/dev/null
    grafana_stopped=true
  fi

  alpine_image=$(vps-compose monitoring --profile logs config --images \
    | awk '/^alpine(@sha256:|:)/ {print; exit}')
  [ -n "$alpine_image" ] || {
    echo "Image Alpine introuvable dans le projet monitoring." >&2
    exit 1
  }

  docker run --rm \
    -v monitoring_grafana_data:/source:ro \
    -v "$staging:/backup" \
    "$alpine_image" \
    tar -czf /backup/grafana-data.tar.gz -C /source .

  if [ "$grafana_stopped" = true ]; then
    vps-compose monitoring start grafana >/dev/null
    grafana_stopped=false
  fi
fi

cat > "$staging/manifest.txt" <<EOF
Date=$(date -Is)
Hôte=$(hostname)
Rétention=${BACKUP_RETENTION_DAYS} jours
EOF

mv "$staging" "$FINAL_DIR"
staging=

find "$BACKUP_ROOT" -mindepth 1 -maxdepth 1 -type d \
  -name '20??-??-??_*' -mtime +"$BACKUP_RETENTION_DAYS" \
  -exec rm -rf -- {} +

echo "Sauvegarde terminée : $FINAL_DIR"
