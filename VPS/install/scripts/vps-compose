#!/bin/sh
set -eu

if [ "$#" -lt 2 ]; then
  echo "Usage : vps-compose SERVICE COMMANDE [ARGUMENTS...]" >&2
  echo "Exemple : vps-compose freshrss up -d" >&2
  exit 2
fi

service=$1
shift
stack="/opt/selfhosted/$service"

case "$service" in
  databases|monitoring|linkwarden|davis|freshrss|ttrss|kill-newsletter|web|gateway) ;;
  *)
    echo "Service inconnu : $service" >&2
    exit 2
    ;;
esac

if [ ! -f "$stack/docker-compose.yml" ]; then
  echo "Projet Compose absent : $stack" >&2
  exit 1
fi

if [ -f "$stack/docker-compose.lock.yml" ]; then
  exec docker compose --project-directory "$stack" \
    -f "$stack/docker-compose.yml" \
    -f "$stack/docker-compose.lock.yml" "$@"
fi

exec docker compose --project-directory "$stack" \
  -f "$stack/docker-compose.yml" "$@"
