#!/bin/sh
set -u

INSTALL_ROOT=${INSTALL_ROOT:-/opt/vps-install}
STACK_ROOT=${STACK_ROOT:-/opt/selfhosted}
REPORT_DIR=${REPORT_DIR:-/var/log/server-checks}
REPORT=${REPORT:-$REPORT_DIR/secret-audit.txt}
SECRETS_FILE=${SECRETS_FILE:-$INSTALL_ROOT/config/secrets.env}
failures=0

[ "$(id -u)" -eq 0 ] || {
  echo "Exécuter cette commande avec sudo ou comme root." >&2
  exit 1
}

[ -r "$SECRETS_FILE" ] || {
  echo "Fichier de secrets absent : $SECRETS_FILE" >&2
  exit 1
}

# shellcheck disable=SC1090
. "$SECRETS_FILE"

install -d -m 0750 "$REPORT_DIR"

check_container_secret() {
  stack=$1
  service=$2
  forbidden_name=$3
  secret_value=$4
  mounted_file=$5

  if [ ! -f "$STACK_ROOT/$stack/docker-compose.yml" ]; then
    echo "IGNORÉ : le projet $stack n'est pas installé."
    return
  fi

  container_id=$(vps-compose "$stack" ps -q "$service" 2>/dev/null)
  if [ -z "$container_id" ]; then
    echo "ÉCHEC : $stack/$service est installé mais n'est pas actif."
    failures=1
    return
  fi

  config_env=$(docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$container_id")
  if printf '%s\n' "$config_env" | grep -q "^${forbidden_name}="; then
    echo "ÉCHEC : $forbidden_name reste présent dans Config.Env de $stack/$service."
    failures=1
  elif [ -n "$secret_value" ] \
    && printf '%s\n' "$config_env" | grep -Fq -- "$secret_value"; then
    echo "ÉCHEC : la valeur de $forbidden_name est visible dans Config.Env de $stack/$service."
    failures=1
  else
    echo "OK : $forbidden_name absent de Config.Env de $stack/$service."
  fi

  if docker exec "$container_id" test -r "$mounted_file"; then
    echo "OK : secret monté et lisible dans $stack/$service."
  else
    echo "ÉCHEC : secret absent dans $stack/$service : $mounted_file."
    failures=1
  fi
}

{
  echo "===== Audit des secrets Docker Compose ====="
  date -Is
  echo

  check_container_secret \
    databases mariadb MARIADB_ROOT_PASSWORD \
    "$MARIADB_ADMIN_PASSWORD" /run/secrets/mariadb_admin_password
  check_container_secret \
    databases mariadb DAVIS_DB_PASSWORD \
    "$DAVIS_DB_PASSWORD" /run/secrets/davis_db_password
  check_container_secret \
    databases mariadb FRESHRSS_DB_PASSWORD \
    "$FRESHRSS_DB_PASSWORD" /run/secrets/freshrss_db_password
  check_container_secret \
    databases mariadb WEB_DB_PASSWORD \
    "$WEB_DB_PASSWORD" /run/secrets/web_db_password
  check_container_secret \
    databases postgres POSTGRES_PASSWORD \
    "$POSTGRES_ADMIN_PASSWORD" /run/secrets/postgres_admin_password
  check_container_secret \
    databases postgres LINKWARDEN_DB_PASSWORD \
    "$LINKWARDEN_DB_PASSWORD" /run/secrets/linkwarden_db_password
  check_container_secret \
    databases postgres TTRSS_DB_PASSWORD \
    "$TTRSS_DB_PASSWORD" /run/secrets/ttrss_db_password
  check_container_secret \
    web app DB_PASSWORD \
    "$WEB_DB_PASSWORD" /run/secrets/web_db_password

  echo
  echo "Hors périmètre : Linkwarden, Davis et Tiny Tiny RSS attendent encore"
  echo "leurs secrets dans des variables d'environnement documentées en amont."
  echo
  echo "Échecs : $failures"
} > "$REPORT" 2>&1

chmod 0640 "$REPORT"
chown root:adm "$REPORT" 2>/dev/null || true
cat "$REPORT"
exit "$failures"
